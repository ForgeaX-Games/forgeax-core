{
  "name": "@forgeax/forgeax-core",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "description": "forgeax-core — self-contained single-agent runtime (agent loop, events, history, capability, provider, compaction). Embeddable natively; also implements the AgentKernel contract as a drop-in kernel. Phase F0 ships the foundation (EventBus block/modify, EventStore, ledger fold, injection interfaces).",
  "main": "./dist/index.js",
  "bin": {
    "forgeax-core": "./dist/cli/main.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./events": "./dist/events/index.js",
    "./history": "./dist/history/index.js",
    "./inject": "./dist/inject/types.js",
    "./cli": "./dist/cli/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build.mjs",
    "pack:tgz": "npm pack",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check:boundaries": "bun scripts/check-core-boundaries.mjs",
    "lint:boundaries": "depcruise --config .dependency-cruiser.cjs src",
    "start": "bun src/cli/main.ts",
    "e2e:real": "bun test/e2e-real.ts",
    "e2e:mcp": "bun test test/mcp",
    "e2e:plan": "bun test/plan-serve-e2e.ts",
    "e2e:subagent": "bun test/subagent-serve-e2e.ts",
    "e2e:paste-image": "bun test/paste-image-e2e.ts",
    "e2e": "bun test/e2e-real.ts && bun test test/mcp && bun test/plan-serve-e2e.ts && bun test/subagent-serve-e2e.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "cli-highlight": "^2",
    "consola": "^3.4.2",
    "diff": "^7",
    "ink": "^6",
    "ink-spinner": "^5",
    "qrcode": "^1.5.4",
    "react": "^19"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/diff": "^7",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "dependency-cruiser": "^17.4.3",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.6.3"
  }
}
